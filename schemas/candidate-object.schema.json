{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verifrax.github.io/tachyrium/schemas/candidate-object.schema.json",
  "title": "TACHYRIUM Candidate Object",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "source_surface",
    "target_surface",
    "status",
    "summary",
    "payload"
  ],
  "properties": {
    "kind": {
      "type": "string",
      "enum": [
        "candidate",
        "draft",
        "summary",
        "suggestion",
        "briefing",
        "analysis"
      ]
    },
    "source_surface": {
      "type": "string",
      "minLength": 1
    },
    "target_surface": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "subordinate",
        "review-required",
        "bounded"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
